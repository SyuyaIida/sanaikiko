                ],
                challengePoints: null
            },
            {
                id: 4,
                name: "「感動体験」を生み出す、オーダーメイド型からくり装置/メカニカルアート制作事業",
                type: "飛躍的アイデア",
                catchphrase: "技術×遊び心！世界を驚かすメカニズム。",
                image: "https://placehold.co/400x250/f9a8d4/ffffff?text=驚く人々が見上げる面白いからくり装置のイラスト",
                overview: "機械設計・製作技術を、従来の産業機械の枠を超えてエンターテイメントやアートの領域に応用し、商業施設、イベント、テーマパーク、あるいは個人向けに、人を驚かせたり感動させたりするオーダーメイドの「からくり装置」やメカニカルアート作品を制作・提供します。",
                points: [
                    "精密な機械技術と、遊び心や物語性のあるアイデアを組み合わせることで、唯一無二の作品を生み出します。",
