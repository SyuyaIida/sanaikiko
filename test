                    { name: "博物館/産業遺産施設", description: "展示用の稼働可能な歴史的機械を探している。" },
                    { name: "特定分野の愛好家/コレクター", description: "希少なレトロ機械の入手やレストアを希望。" },
                    { name: "デザイン事務所/アパレルブランド等", description: "店舗ディスプレイやブランドイメージ構築のためのユニークな機械を求めている。" }
                ],
                steps: [
                    "再生対象とする機械のジャンル選定と専門知識の深化",
                    "国内外のオークションや専門家ネットワークからの情報収集ルート確立",
