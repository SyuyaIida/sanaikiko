                ],
                challengePoints: [
                    "入手困難な部品の調達や代替品の製作技術。",
                    "機械の歴史的価値を正確に評価する鑑定眼の養成。",
                    "ニッチ市場における顧客開拓と信頼関係構築。"
                ]
            }
        ];

        const ideaGrid = document.getElementById('idea-grid');
        const modal = document.getElementById('ideaModal');
        const modalTitle = document.getElementById('modalTitle');
        const modalTabsContainer = document.getElementById('modalTabs');
        const modalTabContentContainer = document.getElementById('modalTabContentContainer');
        const closeModalButton = document.getElementById('closeModal');
        const closeModalFooterButton = document.getElementById('closeModalFooter');
        
        document.getElementById('currentYear').textContent = new Date().getFullYear();

        // アイデアカードを生成して表示
        ideas.forEach(idea => {
            const card = document.createElement('div');
            card.className = 'bg-white rounded-xl shadow-lg overflow-hidden transform hover:scale-105 transition-transform duration-300 cursor-pointer flex flex-col';
            
            let typeColorClass = 'bg-sky-500'; // 現実的アイデア
            if (idea.type === '飛躍的アイデア') {
                typeColorClass = 'bg-pink-500';
            }

            card.innerHTML = `
                <div class="relative">
                    <img src="${idea.image}" alt="${idea.name}" class="w-full h-56 object-cover" onerror="this.onerror=null;this.src='https://placehold.co/400x250/cccccc/969696?text=画像読込失敗';">
                    <span class="absolute top-0 right-0 mt-2 mr-2 text-xs font-semibold text-white px-3 py-1 rounded-full ${typeColorClass}">${idea.type}</span>
                </div>
                <div class="p-6 flex flex-col flex-grow">
                    <h3 class="text-xl font-semibold mb-2 text-slate-800">${idea.name}</h3>
                    <p class="text-sm text-sky-600 font-medium mb-3">${idea.catchphrase}</p>
                    <p class="text-slate-600 text-sm mb-4 line-clamp-3 flex-grow">${idea.overview}</p>
                    <button class="mt-auto w-full bg-sky-600 text-white py-2 px-4 rounded-lg hover:bg-sky-700 transition-colors focus:outline-none focus:ring-2 focus:ring-sky-500 focus:ring-opacity-50">
                        詳細を見る
                    </button>
                </div>
            `;
            card.addEventListener('click', () => openModal(idea));
            ideaGrid.appendChild(card);
        });

        // モーダルを開く関数
        function openModal(idea) {
            modalTitle.textContent = idea.name;
            
            // タブとタブコンテンツをクリア
            modalTabsContainer.innerHTML = '';
            modalTabContentContainer.innerHTML = '';

            const tabsConfig = [
                { key: 'overview', title: '概要' },
                { key: 'points', title: 'ポイント' },
                { key: 'effects', title: '期待される効果' },
                { key: 'synergy', title: '強みとのシナジー' },
                { key: 'targetMarket', title: 'ターゲット市場' },
                { key: 'steps', title: '実現へのステップ' },
            ];

            if (idea.challengePoints && idea.challengePoints.length > 0) {
                tabsConfig.push({ key: 'challengePoints', title: '面白/挑戦ポイント' });
            }
            
            tabsConfig.forEach((tabConfig, index) => {
                // タブボタンの作成
                const tabButton = document.createElement('button');
                tabButton.className = `px-3 py-2 font-medium text-sm rounded-t-lg border-b-2 transition-colors duration-150 ease-in-out`;
                if (index === 0) {
                    tabButton.classList.add('border-sky-500', 'text-sky-600');
                    tabButton.setAttribute('aria-selected', 'true');
                } else {
                    tabButton.classList.add('border-transparent', 'text-slate-500', 'hover:text-slate-700', 'hover:border-slate-300');
                    tabButton.setAttribute('aria-selected', 'false');
                }
                tabButton.textContent = tabConfig.title;
                tabButton.setAttribute('role', 'tab');
                tabButton.setAttribute('data-tab-target', `tab-${tabConfig.key}`);
                modalTabsContainer.appendChild(tabButton);

                // タブコンテンツの作成
                const tabContent = document.createElement('div');
                tabContent.id = `tab-${tabConfig.key}`;
                tabContent.className = 'tab-content p-1';
                if (index === 0) {
                    tabContent.classList.add('active');
                }
                tabContent.setAttribute('role', 'tabpanel');

                let contentHTML = '';
                const ideaData = idea[tabConfig.key];

                if (typeof ideaData === 'string') {
                    contentHTML = `<p class="text-slate-700 leading-relaxed">${ideaData}</p>`;
                } else if (Array.isArray(ideaData)) {
                    if (tabConfig.key === 'targetMarket') {
                        contentHTML = '<ul class="space-y-3">';
                        ideaData.forEach(item => {
                            contentHTML += `<li class="p-3 bg-sky-50 rounded-md border border-sky-200"><strong class="text-sky-700">${item.name}:</strong> <span class="text-slate-600">${item.description}</span></li>`;
                        });
                        contentHTML += '</ul>';
                    } else {
                        contentHTML = '<ul class="list-disc list-inside space-y-2 text-slate-700 leading-relaxed">';
                        ideaData.forEach(item => {
                            contentHTML += `<li>${item}</li>`;
                        });
                        contentHTML += '</ul>';
                    }
                }
                tabContent.innerHTML = contentHTML;
                modalTabContentContainer.appendChild(tabContent);

                // タブ切り替えイベント
                tabButton.addEventListener('click', () => {
                    // すべてのタブボタンから選択状態を解除
                    modalTabsContainer.querySelectorAll('button').forEach(btn => {
                        btn.classList.remove('border-sky-500', 'text-sky-600');
                        btn.classList.add('border-transparent', 'text-slate-500', 'hover:text-slate-700', 'hover:border-slate-300');
                        btn.setAttribute('aria-selected', 'false');
                    });
                    // クリックされたタブを選択状態にする
                    tabButton.classList.add('border-sky-500', 'text-sky-600');
                    tabButton.classList.remove('border-transparent', 'text-slate-500', 'hover:text-slate-700', 'hover:border-slate-300');
                    tabButton.setAttribute('aria-selected', 'true');

                    // すべてのタブコンテンツを非表示
                    modalTabContentContainer.querySelectorAll('.tab-content').forEach(content => {
                        content.classList.remove('active');
                    });
                    // 対応するタブコンテンツを表示
                    document.getElementById(`tab-${tabConfig.key}`).classList.add('active');
                });
            });

            modal.style.display = 'flex';
            document.body.style.overflow = 'hidden'; // 背景のスクロールを禁止
        }

        // モーダルを閉じる関数
        function closeModal() {
            modal.style.display = 'none';
            document.body.style.overflow = 'auto'; // 背景のスクロールを許可
        }

        closeModalButton.addEventListener('click', closeModal);
        closeModalFooterButton.addEventListener('click', closeModal);

        // モーダル外クリックで閉じる
        modal.addEventListener('click', (event) => {
            if (event.target === modal) {
                closeModal();
            }
        });

        // Escキーでモーダルを閉じる
        document.addEventListener('keydown', (event) => {
            if (event.key === 'Escape' && modal.style.display === 'flex') {
                closeModal();
            }
        });

    </script>
</body>
</html>
