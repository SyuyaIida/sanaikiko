                    { name: "商業施設/テーマパーク運営会社", description: "集客力のあるユニークな展示物やアトラクションを求めている。" },
                    { name: "イベント企画会社", description: "記憶に残る体験型コンテンツを探している。" },
                    { name: "富裕層の個人コレクター", description: "自宅や別荘に飾る一点物のアート作品を希望。" }
                ],
                steps: [
                    "社内アイデアコンテストやワークショップの開催",
                    "アーティストやデザイナーとのコラボレーション模索",
